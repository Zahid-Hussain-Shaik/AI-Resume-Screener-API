# ===========================================
# AI Resume Screener API — Environment Config
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ---- Database ----
MYSQL_ROOT_PASSWORD=rootpassword123
MYSQL_DATABASE=resume_screener
DATABASE_URL=mysql+aiomysql://root:rootpassword123@db:3306/resume_screener

# ---- AI Provider ----
# Options: "openai" or "anthropic"
AI_PROVIDER=openai

# OpenAI (required if AI_PROVIDER=openai)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# Anthropic (required if AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ---- AI Settings ----
AI_TIMEOUT=30
AI_MAX_RETRIES=3

# ---- App Settings ----
DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=["*"]
